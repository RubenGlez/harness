{
  "name": "harness",
  "displayName": "Harness",
  "description": "Personal development workflow for Claude Code: 7-step skill chain from ideation to shipping (ideate → product-plan → dev-plan → prototype → implement → qa → update-docs), plus handoff, zoom-out, reusable subagents, the bundled agent-orchestrator MCP, and a parallel dashboard MCP.",
  "author": {
    "name": "Ruben Glez",
    "email": "ruben.daren@gmail.com"
  },
  "homepage": "https://github.com/RubenGlez/harness",
  "repository": "https://github.com/RubenGlez/harness",
  "skills": "./skills/",
  "mcpServers": {
    "agent-orchestrator": {
      "command": "node",
      "args": ["./mcp/agent-orchestrator/index.js"]
    },
    "agent-dashboard": {
      "command": "node",
      "args": ["./mcp/agent-dashboard/index.js"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/block-prototype-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/lint-design.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/harness-gitignore.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/harness-status.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/hooks/handoff-nudge.sh"
          }
        ]
      }
    ]
  }
}
