{
  "name": "harness",
  "displayName": "Harness",
  "description": "Personal development workflow for Claude Code: 8-step skill chain from ideation to shipping (ideate → product-plan → dev-plan → prototype → implement → qa → update-docs → ship), plus a task skill for small changes on shipped products, a next-step recommender, handoff, zoom-out, reusable subagents, and shared global rules.",
  "author": {
    "name": "Ruben Glez"
  },
  "homepage": "https://github.com/RubenGlez/harness",
  "repository": "https://github.com/RubenGlez/harness",
  "skills": "./skills/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/block-dangerous-git.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/block-prototype-commit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/lint-design.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/harness-gitignore.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/harness-status.sh\""
          }
        ]
      }
    ]
  }
}
