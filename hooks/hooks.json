{
  "hooks": {
    "PreToolUse": [
      {
        "id": "block-dangerous-git",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "id": "block-prototype-commit",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/block-prototype-commit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "id": "lint-design",
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/lint-design.sh"
          }
        ]
      },
      {
        "id": "lint-design",
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/lint-design.sh"
          }
        ]
      },
      {
        "id": "harness-gitignore",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/harness-gitignore.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "id": "harness-status",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/harness-status.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "id": "handoff-nudge",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(cat ~/.harness_dir)/scripts/hooks/handoff-nudge.sh"
          }
        ]
      }
    ]
  }
}
